{
  "name": "kory-whisper",
  "version": "0.1.0",
  "description": "基于 Whisper 的本地语音输入工具",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "smoke:windows": "electron . --smoke-windows",
    "build:win:dir": "electron-builder --config electron-builder.config.js --win --dir",
    "build:win:release": "electron-builder --config electron-builder.config.js --win nsis --publish never",
    "test": "node --test tests/*.test.js",
    "test:coverage": "c8 node --test tests/*.test.js",
    "lint": "node scripts/repo-hardgate.js",
    "verify": "npm run lint && npm test && npm run test:coverage",
    "build": "electron-builder --config electron-builder.config.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "whisper",
    "voice",
    "input",
    "macos"
  ],
  "author": "Kory",
  "license": "MIT",
  "devDependencies": {
    "c8": "^10.1.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "node-record-lpcm16": "^1.0.1",
    "opencc-js": "^1.0.5",
    "uiohook-napi": "^1.5.4"
  }
}
