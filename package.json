{
  "name": "kory-whisper",
  "version": "0.1.0",
  "description": "基于 Whisper 的本地语音输入工具",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "whisper",
    "voice",
    "input",
    "macos"
  ],
  "author": "Kory",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "node-global-key-listener": "^0.3.0",
    "node-record-lpcm16": "^1.0.1",
    "opencc-js": "^1.0.5"
  },
  "build": {
    "appId": "com.kory.whisper",
    "productName": "Kory Whisper",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "bin/**/*",
      "node_modules/**/*"
    ],
    "asar": false,
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "models",
        "to": "models",
        "filter": [
          "*.bin"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "entitlements": "build/entitlements.mac.plist",
      "hardenedRuntime": false
    }
  }
}
